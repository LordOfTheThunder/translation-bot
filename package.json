{
  "name": "translation-bot",
  "version": "1.0.0",
  "description": "Discord translation bot using MyMemory API",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --esm src/index.ts",
    "deploy-commands": "ts-node --esm src/bot/deploy-commands.ts",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "discord.js": "^14.14.1",
    "better-sqlite3": "^11.0.0",
    "lru-cache": "^10.2.0",
    "franc": "^6.2.0",
    "pino": "^8.19.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.11.0",
    "@types/better-sqlite3": "^7.6.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "@types/jest": "^29.5.0"
  }
}
